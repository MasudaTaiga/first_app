<h1>トップページ</h1>
<p>@post: <%= @post %></p>
<p>@post.content: <%= @post.content %></p>
<p>@post.created_at: <%= @post.created_at%></p>
<br>

<% @posts.each do |post| %>
  <%= post.content %>
  <%= post.created_at %>
  <br>
<% end %>
<br>
<p>@post_2の表示；<%= @post_2 %>、コメントアウトされた部分の表示：<%# RubyコードをHTMLに埋め込む %></p>
<!--↑未定義のインスタンス変数を表示するように書くと、エラーではなく何も埋め込まれないようになりました -->


<h1>トップページ</h1>
<% @posts.each do |post| %>
  <div class="post">
    <div class="post-date">
      投稿日時：<%= post.created_at %>
    </div>
    <div class="post-content">
      <%= post.content %>
    </div>
  </div>
<% end %>



<%= link_to '新規投稿', '/posts/new', method: :GET %>